    {
      "parameters": {
        "jsCode": "const quotes = [\n  \"You’ve got this today.\",\n  \"Keep going. You’re building something meaningful.\",\n  \"Small steps today, big results tomorrow.\",\n  \"Show up today. That’s enough.\",\n  \"Stay consistent. It compounds.\",\n  \"You’re closer than you think.\"\n];\n\nconst day = Math.floor(Date.now() / (1000 * 60 * 60 * 24));\nconst index = Math.floor(day / 2) % quotes.length;\n\nreturn [{ quote: quotes[index] }];"
      },
