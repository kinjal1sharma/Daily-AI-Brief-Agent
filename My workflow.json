    {
      "parameters": {
        "jsCode": "// Remove duplicates + keep recent + prioritize strong signals\n\nconst seen = new Set();\nconst filtered = [];\n\nfor (const item of items) {\n  const title = item.json.title;\n\n  if (!title || seen.has(title)) continue;\n  seen.add(title);\n\n  filtered.push(item);\n}\n\n// Optional: prioritize by keywords\nconst priorityKeywords = [\n  \"AI\",\n  \"OpenAI\",\n  \"Google\",\n  \"startup\",\n  \"funding\",\n  \"YC\",\n  \"Sequoia\",\n  \"war\",\n  \"China\",\n  \"US\",\n  \"sanctions\",\n  \"conflict\"\n];\n\nfiltered.sort((a, b) => {\n  const aScore = priorityKeywords.some(k => a.json.title?.includes(k)) ? 1 : 0;\n  const bScore = priorityKeywords.some(k => b.json.title?.includes(k)) ? 1 : 0;\n  return bScore - aScore;\n});\n\n// Keep top 15\nreturn filtered.slice(0, 15);"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
